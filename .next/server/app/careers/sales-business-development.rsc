14:T8ad,[{"@context":"https://schema.org","@type":"JobPosting","title":"Sales & Business Development","description":"Mengembangkan peluang bisnis baru, membangun relasi klien, dan mendorong pencapaian target penjualan layanan media placement Glassbox.\n\nTanggung jawab:\n\n- Mencari dan mengelola pipeline prospek klien baru secara aktif.\n\n- Menyiapkan proposal penawaran dan presentasi layanan sesuai kebutuhan klien.\n\n- Membangun relasi jangka panjang dengan klien dan partner strategis.\n\n- Berkoordinasi dengan tim operasional untuk memastikan delivery kampanye.\n\n- Mencapai target penjualan bulanan/kuartalan dan menyusun laporan aktivitas.\n\nPersyaratan:\n\n- Pendidikan minimal D3/S1 dari semua jurusan.\n\n- Memiliki pengalaman sales B2B, media, advertising, atau agency menjadi nilai tambah.\n\n- Komunikatif, percaya diri saat presentasi, dan negosiasi yang baik.\n\n- Terbiasa dengan proses penjualan end-to-end (prospecting sampai closing).\n\n- Mampu bekerja mandiri maupun kolaboratif dalam tim.\n\nBenefit:\n\n- Gaji pokok kompetitif.\n\n- Insentif dan komisi berdasarkan performa.\n\n- Kesempatan networking dengan brand dan partner besar.\n\n- Lingkungan kerja agile dan suportif.","datePosted":"2026-04-14","employmentType":"https://schema.org/FullTime","hiringOrganization":{"@type":"Organization","name":"Glassbox","sameAs":"https://glassbox.id","logo":"https://glassbox.id/logo.png"},"jobLocation":{"@type":"Place","address":{"@type":"PostalAddress","streetAddress":"Gedung perkantoran (isi alamat kantor resmi Glassbox)","addressLocality":"Jakarta","addressRegion":"DKI Jakarta","postalCode":"10110","addressCountry":"ID"}},"baseSalary":{"@type":"MonetaryAmount","currency":"IDR","value":{"@type":"QuantitativeValue","minValue":7000000,"maxValue":16000000,"unitText":"MONTH"}},"url":"https://glassbox.id/careers/sales-business-development","validThrough":"2026-05-15T23:59:59+07:00"},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://glassbox.id"},{"@type":"ListItem","position":2,"name":"Karir","item":"https://glassbox.id/careers"},{"@type":"ListItem","position":3,"name":"Sales & Business Development"}]}]c:{"metadata":[["$","title","0",{"children":"Sales & Business Development | Glassbox | Glassbox"}],["$","meta","1",{"name":"description","content":"Mengembangkan peluang bisnis baru, membangun relasi klien, dan mendorong pencapaian target penjualan layanan media placement Glassbox."}],["$","meta","2",{"name":"keywords","content":"digital signage,OOH advertising,DOOH,iklan luar ruang,periklanan outdoor,media placement,Jakarta,Indonesia,Glassbox"}],["$","meta","3",{"name":"google-site-verification","content":"WCtE1vFuxxy-JRH2YrsR3llXMkYdfg1kredJN91YbyU"}],["$","meta","4",{"name":"geo.region","content":"ID-JK"}],["$","meta","5",{"name":"geo.placename","content":"Jakarta"}],["$","meta","6",{"name":"geo.position","content":"-6.2088;106.8456"}],["$","meta","7",{"name":"ICBM","content":"-6.2088, 106.8456"}],["$","meta","8",{"name":"script:ld+json","content":"$14"}],["$","link","9",{"rel":"canonical","href":"https://glassbox.id/careers/sales-business-development"}],["$","meta","10",{"property":"og:title","content":"Sales & Business Development | Glassbox"}],["$","meta","11",{"property":"og:description","content":"Mengembangkan peluang bisnis baru, membangun relasi klien, dan mendorong pencapaian target penjualan layanan media placement Glassbox."}],"$L15","$L16","$L17","$L18","$L19","$L1a"],"error":null,"digest":"$undefined"}
